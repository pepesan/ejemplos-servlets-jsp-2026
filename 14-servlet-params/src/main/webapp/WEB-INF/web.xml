<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>14 - Parámetros GET y POST</display-name>

    <servlet>
        <servlet-name>paramsGet</servlet-name>
        <servlet-class>com.cursosdedesarrollo.ParamsGetServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>paramsGet</servlet-name>
        <url-pattern>/get</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>paramsPost</servlet-name>
        <servlet-class>com.cursosdedesarrollo.ParamsPostServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>paramsPost</servlet-name>
        <url-pattern>/post</url-pattern>
    </servlet-mapping>

</web-app>
