<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>13 - HttpServletRequest y HttpServletResponse</display-name>

    <servlet>
        <servlet-name>inspeccionRequest</servlet-name>
        <servlet-class>com.cursosdedesarrollo.InspeccionRequestServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>inspeccionRequest</servlet-name>
        <url-pattern>/request</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>tiposRespuesta</servlet-name>
        <servlet-class>com.cursosdedesarrollo.TiposRespuestaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>tiposRespuesta</servlet-name>
        <url-pattern>/respuesta</url-pattern>
    </servlet-mapping>

</web-app>
