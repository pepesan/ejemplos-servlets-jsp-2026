<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <property name="connection.driver_class">org.h2.Driver</property>
        <property name="connection.url">jdbc:h2:mem:cursodb52xml;DB_CLOSE_DELAY=-1</property>
        <property name="connection.username">sa</property>
        <property name="connection.password"></property>

        <property name="dialect">org.hibernate.dialect.H2Dialect</property>
        <property name="hbm2ddl.auto">create-drop</property>
        <property name="show_sql">true</property>

        <!-- ── OneToOne (unoauno) ──────────────────────────────────── -->
        <!-- Unidireccional: Persona → Pasaporte -->
        <mapping resource="com/cursosdedesarrollo/unoauno/Pasaporte.hbm.xml"/>
        <mapping resource="com/cursosdedesarrollo/unoauno/Persona.hbm.xml"/>
        <!-- Bidireccional: Usuario ↔ Perfil -->
        <mapping resource="com/cursosdedesarrollo/unoauno/Perfil.hbm.xml"/>
        <mapping resource="com/cursosdedesarrollo/unoauno/Usuario.hbm.xml"/>

        <!-- ── OneToMany (unoamuchos) ──────────────────────────────── -->
        <!-- Unidireccional: Categoria → Articulo -->
        <mapping resource="com/cursosdedesarrollo/unoamuchos/Articulo.hbm.xml"/>
        <mapping resource="com/cursosdedesarrollo/unoamuchos/Categoria.hbm.xml"/>
        <!-- Bidireccional: Departamento ↔ Empleado -->
        <mapping resource="com/cursosdedesarrollo/unoamuchos/Empleado.hbm.xml"/>
        <mapping resource="com/cursosdedesarrollo/unoamuchos/Departamento.hbm.xml"/>

        <!-- ── ManyToMany (muchosamuchos) ────────────────────────── -->
        <!-- Unidireccional: Producto → Etiqueta -->
        <mapping resource="com/cursosdedesarrollo/muchosamuchos/Etiqueta.hbm.xml"/>
        <mapping resource="com/cursosdedesarrollo/muchosamuchos/Producto.hbm.xml"/>
        <!-- Bidireccional: Pelicula ↔ Actor -->
        <mapping resource="com/cursosdedesarrollo/muchosamuchos/Actor.hbm.xml"/>
        <mapping resource="com/cursosdedesarrollo/muchosamuchos/Pelicula.hbm.xml"/>

    </session-factory>
</hibernate-configuration>
