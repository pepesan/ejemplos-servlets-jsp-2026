<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <property name="connection.driver_class">org.h2.Driver</property>
        <property name="connection.url">jdbc:h2:mem:cursodb52;DB_CLOSE_DELAY=-1</property>
        <property name="connection.username">sa</property>
        <property name="connection.password"></property>

        <property name="dialect">org.hibernate.dialect.H2Dialect</property>
        <property name="hbm2ddl.auto">create-drop</property>
        <property name="show_sql">true</property>

        <!-- ── OneToOne (unoauno) ──────────────────────────────────── -->
        <!-- Unidireccional: Persona → Pasaporte -->
        <mapping class="com.cursosdedesarrollo.unoauno.Pasaporte"/>
        <mapping class="com.cursosdedesarrollo.unoauno.Persona"/>
        <!-- Bidireccional: Usuario ↔ Perfil -->
        <mapping class="com.cursosdedesarrollo.unoauno.Perfil"/>
        <mapping class="com.cursosdedesarrollo.unoauno.Usuario"/>

        <!-- ── OneToMany (unoamuchos) ──────────────────────────────── -->
        <!-- Unidireccional: Categoria → Articulo -->
        <mapping class="com.cursosdedesarrollo.unoamuchos.Articulo"/>
        <mapping class="com.cursosdedesarrollo.unoamuchos.Categoria"/>
        <!-- Bidireccional: Departamento ↔ Empleado -->
        <mapping class="com.cursosdedesarrollo.unoamuchos.Empleado"/>
        <mapping class="com.cursosdedesarrollo.unoamuchos.Departamento"/>

        <!-- ── ManyToMany (muchosamuchos) ────────────────────────── -->
        <!-- Unidireccional: Producto → Etiqueta -->
        <mapping class="com.cursosdedesarrollo.muchosamuchos.Etiqueta"/>
        <mapping class="com.cursosdedesarrollo.muchosamuchos.Producto"/>
        <!-- Bidireccional: Pelicula ↔ Actor -->
        <mapping class="com.cursosdedesarrollo.muchosamuchos.Actor"/>
        <mapping class="com.cursosdedesarrollo.muchosamuchos.Pelicula"/>

    </session-factory>
</hibernate-configuration>
