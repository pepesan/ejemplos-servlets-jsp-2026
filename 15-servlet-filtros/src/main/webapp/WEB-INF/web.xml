<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>15 - Filtros de Servlet</display-name>

    <!-- ═══════════════════════════════════════════════════════════════════
         FILTROS — se ejecutan en el orden en que aparecen los filter-mapping
         ═══════════════════════════════════════════════════════════════════ -->

    <!-- 1. CharsetFilter: fija UTF-8 antes de que nadie lea parámetros -->
    <filter>
        <filter-name>charsetFilter</filter-name>
        <filter-class>com.cursosdedesarrollo.CharsetFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>charsetFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 2. LoggingFilter: registra método, URI y tiempo de respuesta -->
    <filter>
        <filter-name>loggingFilter</filter-name>
        <filter-class>com.cursosdedesarrollo.LoggingFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>loggingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 3. AuthFilter: protege rutas bajo /protegido/* -->
    <filter>
        <filter-name>authFilter</filter-name>
        <filter-class>com.cursosdedesarrollo.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>authFilter</filter-name>
        <url-pattern>/protegido/*</url-pattern>
    </filter-mapping>

    <!-- ═══════════════════════════════════════════════════════════════════
         SERVLETS
         ═══════════════════════════════════════════════════════════════════ -->

    <servlet>
        <servlet-name>login</servlet-name>
        <servlet-class>com.cursosdedesarrollo.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>login</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>protegido</servlet-name>
        <servlet-class>com.cursosdedesarrollo.ProtegidoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>protegido</servlet-name>
        <url-pattern>/protegido/area</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>logout</servlet-name>
        <servlet-class>com.cursosdedesarrollo.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>logout</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

</web-app>
