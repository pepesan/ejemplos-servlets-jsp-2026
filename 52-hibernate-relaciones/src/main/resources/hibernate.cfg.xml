<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <property name="connection.driver_class">org.h2.Driver</property>
        <property name="connection.url">jdbc:h2:mem:cursodb52;DB_CLOSE_DELAY=-1</property>
        <property name="connection.username">sa</property>
        <property name="connection.password"></property>

        <property name="dialect">org.hibernate.dialect.H2Dialect</property>
        <property name="hbm2ddl.auto">create-drop</property>
        <property name="show_sql">true</property>

        <!-- OneToOne unidireccional -->
        <mapping class="com.cursosdedesarrollo.Pasaporte"/>
        <mapping class="com.cursosdedesarrollo.Persona"/>

        <!-- OneToOne bidireccional -->
        <mapping class="com.cursosdedesarrollo.Perfil"/>
        <mapping class="com.cursosdedesarrollo.Usuario"/>

        <!-- OneToMany unidireccional -->
        <mapping class="com.cursosdedesarrollo.Articulo"/>
        <mapping class="com.cursosdedesarrollo.Categoria"/>

        <!-- OneToMany bidireccional -->
        <mapping class="com.cursosdedesarrollo.Empleado"/>
        <mapping class="com.cursosdedesarrollo.Departamento"/>

        <!-- ManyToMany unidireccional -->
        <mapping class="com.cursosdedesarrollo.Etiqueta"/>
        <mapping class="com.cursosdedesarrollo.Producto"/>

        <!-- ManyToMany bidireccional -->
        <mapping class="com.cursosdedesarrollo.Actor"/>
        <mapping class="com.cursosdedesarrollo.Pelicula"/>

    </session-factory>
</hibernate-configuration>
