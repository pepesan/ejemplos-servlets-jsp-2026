<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <display-name>17 - Sesiones HTTP</display-name>

    <servlet>
        <servlet-name>sesion</servlet-name>
        <servlet-class>com.cursosdedesarrollo.SesionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>sesion</servlet-name>
        <url-pattern>/sesion</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>contador</servlet-name>
        <servlet-class>com.cursosdedesarrollo.ContadorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>contador</servlet-name>
        <url-pattern>/contador</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>carrito</servlet-name>
        <servlet-class>com.cursosdedesarrollo.CarritoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>carrito</servlet-name>
        <url-pattern>/carrito</url-pattern>
    </servlet-mapping>

    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>
</web-app>
