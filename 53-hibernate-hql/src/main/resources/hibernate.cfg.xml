<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <property name="connection.driver_class">org.h2.Driver</property>
        <property name="connection.url">jdbc:h2:mem:cursodb53;DB_CLOSE_DELAY=-1</property>
        <property name="connection.username">sa</property>
        <property name="connection.password"></property>

        <property name="dialect">org.hibernate.dialect.H2Dialect</property>
        <property name="hbm2ddl.auto">create-drop</property>
        <property name="show_sql">true</property>

        <!-- Herencia SINGLE_TABLE -->
        <mapping class="com.cursosdedesarrollo.Persona"/>
        <mapping class="com.cursosdedesarrollo.EmpleadoST"/>
        <mapping class="com.cursosdedesarrollo.Cliente"/>

        <!-- Herencia JOINED -->
        <mapping class="com.cursosdedesarrollo.Vehiculo"/>
        <mapping class="com.cursosdedesarrollo.Coche"/>
        <mapping class="com.cursosdedesarrollo.Moto"/>

        <!-- Herencia TABLE_PER_CLASS -->
        <mapping class="com.cursosdedesarrollo.Pago"/>
        <mapping class="com.cursosdedesarrollo.PagoTarjeta"/>
        <mapping class="com.cursosdedesarrollo.PagoEfectivo"/>

        <!-- Entidad para ejemplos HQL -->
        <mapping class="com.cursosdedesarrollo.Producto"/>

    </session-factory>
</hibernate-configuration>
